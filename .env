# ─── Database (Vercel Postgres / Neon) ───
# After creating a Vercel Postgres database, this URL will be auto-set by Vercel.
# For local dev, use your Neon connection string.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ─── Vercel Blob (Image Uploads) ───
# After creating a Vercel Blob store, this token will be auto-set by Vercel.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ─── Email (Resend) ───
RESEND_API_KEY="re_xxx"
CONTACT_EMAIL="hello@idilsh.top"

# ─── Google Sheets Integration ───
GOOGLE_SHEET_URL="https://script.google.com/macros/s/xxx/exec"
