generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String   @default("")
  content       String   @default("")
  category      String   @default("Uncategorized")
  date          String   @default("2026-01-01")
  readTime      String   @default("5 min read")
  featured      Boolean  @default(false)
  published     Boolean  @default(false)
  keywords      String[] @default([])
  featuredImage String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PortfolioProject {
  id          Int      @id @default(autoincrement())
  title       String
  client      String   @default("")
  category    String   @default("Branding")
  description String   @default("")
  imageUrl    String   @default("")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id           Int    @id @default(1)
  siteName     String @default("iDilsh Network")
  siteTagline  String @default("Ignite Designs. Illuminate Dreams.")
  siteUrl      String @default("https://idilsh.top")
  contactEmail String @default("hello@idilsh.top")
  whatsappLink String @default("https://wa.me/94773226376")
  navLogoUrl   String @default("/logo.svg")
  heroLogoUrl  String @default("/hero-logo.png")
}
